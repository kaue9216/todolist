<div class="tasks-container">
  <% @tasks.each do |task| %>
    <div class="task-card <%= 'completed' if task.done %>">
      <div class="task-header">
        <span class="task-title"><%= task.task %></span>
        <% if task.done %>
          <span class="task-status-badge">Tarefa Concluida ✓</span>
        <% end %>
        <span class="task-date"><%= task.date %></span>
        <div class="task-actions">
          <%= link_to "Ver tarefa", edit_task_path(task), class: 'edit-button' %>
          <button class="dropdown-button" onclick="toggleDescription(this)">▼</button>
        </div>
      </div>
      <div class="task-description" style="display: none;">
        <p><%= task.description %></p>
      </div>
    </div>
  <% end %>


</div>


<script>
  function toggleDescription(button) {
    const description = button.closest('.task-card').querySelector('.task-description');
    description.style.display = description.style.display === 'none' ? 'block' : 'none';
    button.textContent = description.style.display === 'none' ? '▼' : '▲';
  }
</script>
